Table user {
  id_user int [pk]
  name varchar(255) [not null]
  email varchar(255) [not null, unique]
}

Table project {
  id_project int [pk]
  name varchar(255) [not null]
  description text
  created_by_user_id int [not null]
}

Table technology {
  id_technology int [pk]
  name varchar(100) [not null, unique]
  slug varchar(100) [not null, unique]
  created_by_user_id int
}

Table project_stack {
  id_project int [pk]
  id_technology int [pk]
  indexes {
    (id_project, id_technology) [pk]
  }
}

Ref: user.id_user > project.created_by_user_id

Ref: user.id_user > technology.created_by_user_id

Ref: project.id_project > project_stack.id_project

Ref: technology.id_technology > project_stack.id_technology

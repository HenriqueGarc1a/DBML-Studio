// opacity=1
Table report {
  id uuid [pk]
  student_id uuid [not null]
  create_date timestamp [not null]
  edit_date timestamp [not null]
  grade numeric(4,2)
  type report_type [not null]
  url_archive varchar(255)
  comment text
  correction_url varchar(255)
  revision_date timestap
}


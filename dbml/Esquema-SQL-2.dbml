// @table ages_user
// x=2280
// y=740
// width=380
// height=262
// useDefaultStyle=false
// useGroupStyle=true
// background=#111827
// border=#4b5f78
// header=#253142
// text=#e5edf7
// line=#94a3b8
// opacity=1
Table ages_user {
  id uuid [pk]
  email varchar(255) [not null]
  pucrs_id char(8) [not null]
  name varchar(255) [not null]
  password varchar(255) [not null]
  image_url varchar(255)
  course course [not null]
  type user_type [not null]
}

// @table project
// x=3300
// y=740
// width=380
// height=290
// useDefaultStyle=false
// useGroupStyle=true
// background=#111827
// border=#4b5f78
// header=#253142
// text=#e5edf7
// line=#94a3b8
// opacity=1
Table project {
  id uuid [pk]
  description text [not null]
  git_lab varchar(255)
  name varchar(255) [not null]
  active boolean [not null]
  group_photo_url varchar(255)
  year int [not null]
  semester semester [not null]
  logo_url varchar(255)
}

// @table team

// @table project_stack
// x=3780
// y=740
// width=380
// height=122
// useDefaultStyle=false
// useGroupStyle=true
// background=#111827
// border=#4b5f78
// header=#253142
// text=#e5edf7
// line=#94a3b8
// opacity=1
Table project_stack {
  id uuid [pk]
  project_id uuid [not null]
  technology_id uuid [not null]
  indexes {
    (project_id, technology_id) [unique]
  }
}

// @table report
// x=2820
// y=-100

// @table sprint_report
// x=3780
// y=-100
// width=380
// height=262
// useDefaultStyle=false
// useGroupStyle=true
// background=#111827
// border=#4b5f78
// header=#253142
// text=#e5edf7
// line=#94a3b8
// opacity=1
Table sprint_report {
  id uuid [pk]
  activity_completed text [not null]
  learned_lessons text [not null]
  next_steps text [not null]
  predicted_activity text [not null]
  problems_encountered text [not null]
  sprint sprint [not null]
  report_id uuid [not null, unique]
}

// @table hours_report
// x=3300
// y=-100
// width=380
// height=234
// useDefaultStyle=false
// useGroupStyle=true
// background=#111827
// border=#4b5f78
// header=#253142
// text=#e5edf7
// line=#94a3b8
// opacity=1
Table hours_report {
  id uuid [pk]
  activities text
  entry_time timestamp [not null]
  exit_time timestamp
  rejection_justification text
  approved boolean [not null]
  report_id uuid [not null, unique]
}


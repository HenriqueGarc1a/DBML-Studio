// @table ages_user
// x=1700
// y=330.4
// width=282
// height=262
// useDefaultStyle=true
// useGroupStyle=false
Table ages_user {
  id uuid [pk]
  email varchar(255) [not null]
  pucrs_id char(8) [not null]
  name varchar(255) [not null]
  password varchar(255) [not null]
  image_url varchar(255)
  course course [not null]
  type user_type [not null]
}

// @table project
// x=1700
// y=799.3
// width=330
// height=290
// useDefaultStyle=true
// useGroupStyle=false
Table project {
  id uuid [pk]
  description text [not null]
  git_lab varchar(255)
  name varchar(255) [not null]
  active boolean [not null]
  group_photo_url varchar(255)
  year int [not null]
  semester semester [not null]
  logo_url varchar(255)
}

// @table team
// x=1348
// y=814.7
// width=226
// height=122
// useDefaultStyle=true
// useGroupStyle=false
Table team {
  id uuid [pk]
  teacher_id uuid [not null]
  project_id uuid [not null]
}

// @table class
// x=1326.7
// y=63.7
// width=242
// height=206
// useDefaultStyle=true
// useGroupStyle=false
Table class {
  id uuid [pk]
  number int [not null]
  year int [not null]
  semester semester [not null]
  teacher_id uuid [not null]
  active boolean [not null]
}

// @table semester_profile
// x=860
// y=438.7
// width=346
// height=234
// useDefaultStyle=true
// useGroupStyle=false
Table semester_profile {
  id uuid [pk]
  grade numeric(4,2)
  ages_role ages_role [not null]
  student_status semester_status [not null]
  user_id uuid [not null]
  team_id uuid [not null]
  class_id uuid [not null]
}

// @table lesson
// x=923
// y=71.3
// width=220
// height=122
// useDefaultStyle=true
// useGroupStyle=false
Table lesson {
  id uuid [pk]
  date timestamp [not null]
  class_id uuid [not null]
}

// @table otp
// x=1324
// y=566.7
// width=266
// height=178
// useDefaultStyle=true
// useGroupStyle=false
Table otp {
  id uuid [pk]
  user_id uuid [not null]
  expires_at timestamp [not null]
  token varchar(255) [not null]
  used boolean [not null]
}

// @table schedule
// x=1316
// y=339.7
// width=274
// height=206
// useDefaultStyle=true
// useGroupStyle=false
Table schedule {
  id uuid [pk]
  admin_id uuid [not null]
  event char(10) [not null]
  event_date timestamp [not null]
  event_period char(10) [not null]
  event_time time(0) [not null]
}

// @table technology
// x=1700
// y=1159.3
// width=266
// height=122
// useDefaultStyle=true
// useGroupStyle=false
Table technology {
  id uuid [pk]
  name varchar(255) [not null]
  type technology_type [not null]
}

// @table project_stack
// x=1340
// y=1139
// width=250
// height=122
// useDefaultStyle=true
// useGroupStyle=false
Table project_stack {
  id uuid [pk]
  project_id uuid [not null]
  technology_id uuid [not null]
  indexes {
    (project_id, technology_id) [unique]
  }
}

// @table report
// x=452
// y=714.7
// width=298
// height=234
// useDefaultStyle=true
// useGroupStyle=false
Table report {
  id uuid [pk]
  student_id uuid [not null]
  create_date timestamp [not null]
  edit_date timestamp [not null]
  grade numeric(4,2)
  type report_type [not null]
  url_archive varchar(255)
}

// @table examining_board
// x=476
// y=466.7
// width=250
// height=178
// useDefaultStyle=true
// useGroupStyle=false
Table examining_board {
  id uuid [pk]
  date date [not null]
  grade numeric(4,2) [not null]
  room varchar(255) [not null]
  student_id uuid [not null]
}

// @table examining_board_member
// x=52
// y=12
// width=290
// height=122
// useDefaultStyle=true
// useGroupStyle=false
Table examining_board_member {
  id uuid [pk]
  examining_board_id uuid [not null]
  teacher_id uuid [not null]
}

// @table attendance
// x=524
// y=91.7
// width=226
// height=122
// useDefaultStyle=true
// useGroupStyle=false
Table attendance {
  id uuid [pk]
  lesson_id uuid [not null]
  student_id uuid [not null]
}

// @table report_review
// x=20
// y=466.7
// width=322
// height=178
// useDefaultStyle=true
// useGroupStyle=false
Table report_review {
  id uuid [pk]
  comment text [not null]
  correction_url varchar(255) [not null]
  revision_date timestamp [not null]
  report_id uuid [not null, unique]
}

// @table sprint_report
// x=36
// y=1018.7
// width=306
// height=262
// useDefaultStyle=true
// useGroupStyle=false
Table sprint_report {
  id uuid [pk]
  activity_completed text [not null]
  learned_lessons text [not null]
  next_steps text [not null]
  predicted_activity text [not null]
  problems_encountered text [not null]
  sprint sprint [not null]
  report_id uuid [not null, unique]
}

// @table hours_report
// x=12
// y=714.7
// width=330
// height=234
// useDefaultStyle=true
// useGroupStyle=false
Table hours_report {
  id uuid [pk]
  activities text
  entry_time timestamp [not null]
  exit_time timestamp
  rejection_justification text
  approved boolean [not null]
  report_id uuid [not null, unique]
}


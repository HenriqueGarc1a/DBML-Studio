// @table user
// x=-64
// y=88
// width=250
// height=122
// useDefaultStyle=true
// useGroupStyle=false
Table user {
  id_user int [pk]
  name varchar(255) [not null]
  email varchar(255) [not null, unique]
}

// @table project
// x=336
// y=240
// width=282
// height=150
// useDefaultStyle=true
// useGroupStyle=false
Table project {
  id_project int [pk]
  name varchar(255) [not null]
  description text
  created_by_user_id int [not null]
}

// @table technology
// x=360
// y=-44
// width=282
// height=150
// useDefaultStyle=true
// useGroupStyle=false
Table technology {
  id_technology int [pk]
  name varchar(100) [not null, unique]
  slug varchar(100) [not null, unique]
  created_by_user_id int
}

// @table project_stack
// x=760
// y=56
// width=242
// height=94
// useDefaultStyle=true
// useGroupStyle=false
Table project_stack {
  id_project int [pk]
  id_technology int [pk]
  indexes {
    (id_project, id_technology) [pk]
  }
}


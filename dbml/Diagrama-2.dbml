// @table User
// x=-356
// y=316
// width=282
// height=458
// useDefaultStyle=true
// useGroupStyle=false
Table User {
  id uuid [pk]
  full_name String
  email String
  password String
  phone_number String
  birth_date datetime
  role Role
  plan_end_date DateTime
  streak Int
  coins Int
  createdAt DateTime
  enable Boolean
  desired_course String
  desired_exam String
  last_active DateTime
}

// @table Exam
// x=116
// y=-376
// width=234
// height=150
// useDefaultStyle=true
// useGroupStyle=false
Table Exam {
  id uuid [pk]
  name String
  origin String
  image_url String
}

// @table ExamDay
// x=1016
// y=36
// width=346
// height=122
// useDefaultStyle=true
// useGroupStyle=false
Table ExamDay {
  id uuid [pk]
  int day
  exam_id uuid
}

// @table Attempt
// x=-320
// y=-404
// width=282
// height=262
// useDefaultStyle=true
// useGroupStyle=false
Table Attempt {
  id uuid [pk, fk]
  exam_id uuid
  user_id uuid
  time_spent_minutes Int
  score Int
  language Language
  init_time DateTime
  end_time DateTime
}

// @table Attempt_day
// x=504
// y=-124
// width=282
// height=234
// useDefaultStyle=true
// useGroupStyle=false
Table Attempt_day {
  id uuid [pk]
  time_spent_minutes Int
  current_question Int
  init_time DateTime
  end_time DateTime
  exam_day_id uuid
  attempt_id uuid
}

// @table Subject
// x=-272
// y=1248
// width=220
// height=94
// useDefaultStyle=true
// useGroupStyle=false
Table Subject {
  id uuid [pk]
  name String
}

// @table Path
// x=-288
// y=928
// width=274
// height=206
// useDefaultStyle=true
// useGroupStyle=false
Table Path {
  id uuid [pk]
  subject_id uuid
  name String
  text String
  schedule_position Int
  trail_position Int
}

// @table StudyDay
// x=-692
// y=584
// width=220
// height=150
// useDefaultStyle=true
// useGroupStyle=false
Table StudyDay {
  id uuid [pk]
  user_id uuid
  day WeekDay
  hour Int
}

// @table StudyLog
// x=-700
// y=904
// width=220
// height=178
// useDefaultStyle=true
// useGroupStyle=false
Table StudyLog {
  id uuid [pk]
  date DateTime
  done Boolean
  path_id uuid
  user_id uuid
}

// @table Question
// x=48
// y=576
// width=242
// height=318
// useDefaultStyle=true
// useGroupStyle=false
Table Question {
  id uuid [pk]
  path_id uuid
  exam_day_id uuid
  text String
  origin Origin
  year Int
  feedback String
  number Int
  language Language
  image_url String
}

// @table Alternative
// x=428
// y=636
// width=250
// height=178
// useDefaultStyle=true
// useGroupStyle=false
Table Alternative {
  id uuid [pk]
  text String
  letter char(1)
  is_correct Boolean
  question_id uuid
}

// @table Answer
// x=-532
// y=64
// width=266
// height=206
// useDefaultStyle=true
// useGroupStyle=false
Table Answer {
  id uuid [pk]
  answer_date DateTime
  alternative_id uuid
  user_id uuid
  question_id uuid
  attempt_day_id uuid
}

